# Copie este arquivo para .env e preencha com suas credenciais.
# O .env nunca deve ser commitado — ele já está no .gitignore.

# ─── Groq ─────────────────────────────────────────────────────────────────────
# Obtenha em: https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# ─── Anthropic Claude ─────────────────────────────────────────────────────────
# Obtenha em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── Twilio ───────────────────────────────────────────────────────────────────
# Obtenha em: https://console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
