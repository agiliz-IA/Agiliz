# Copie este arquivo para .env e preencha com suas credenciais.
# O .env nunca deve ser commitado — ele já está no .gitignore.

# ─── Groq ─────────────────────────────────────────────────────────────────────
# Obtenha em: https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# ─── Anthropic Claude ─────────────────────────────────────────────────────────
# Obtenha em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── Evolution API - Banco de Dados ────────────────────────────────────────────────────────────────
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://evolution:evolution@postgres:5432/evolution
DATABASE_CONNECTION_CLIENT_NAME=evolution_exchange
DATABASE_SAVE_DATA_INSTANCE=true
DATABASE_SAVE_DATA_NEW_MESSAGE=true
DATABASE_SAVE_MESSAGE_UPDATE=true
DATABASE_SAVE_DATA_CONTACTS=true
DATABASE_SAVE_DATA_CHATS=true
DATABASE_SAVE_DATA_LABELS=true
DATABASE_SAVE_DATA_HISTORIC=true

# ─── Evolution API - Redis Cache ──────────────────────────────────────────────────────────────────
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://redis:6379/1
CACHE_REDIS_PREFIX_KEY=evolution
CACHE_REDIS_SAVE_INSTANCES=false
CACHE_LOCAL_ENABLED=false

# ─── Evolution API - Servidor ─────────────────────────────────────────────────────────────────────
SERVER_URL=http://localhost:8080
DEL_INSTANCE=false
CORS_ORIGIN=*
AUTHENTICATION_API_KEY=429683C4C977415CAAFCCE10F7D57E11

# ─── Agiliz Runtime - Evolution API Client ────────────────────────────────────────────────────────
EVOLUTION_API_TOKEN=your-token-here


